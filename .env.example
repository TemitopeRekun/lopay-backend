NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Authentication (Better Auth)
BETTER_AUTH_SECRET="replace-with-strong-secret-min-32-chars"
BETTER_AUTH_URL="http://localhost:3001"
# Google OAuth (web first; Android client id optional until native Google ships)
GOOGLE_WEB_CLIENT_ID=""
GOOGLE_WEB_CLIENT_SECRET=""
GOOGLE_ANDROID_CLIENT_ID=""

# Supabase Storage (Private bucket + backend-signed URLs)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="your-private-bucket-name"
# Optional: default 600 seconds (10 minutes)
SUPABASE_SIGNED_URL_TTL_SECONDS=600

# Optional Admin Seed Config
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Optional CORS allowlist (comma-separated)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=""

# Paystack (split payments for first-payment collection + settlement)
# Use the test secret key (sk_test_...) in development.
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Optional: comma-separated allowlist of Paystack webhook source IPs
# (52.31.139.75,52.49.173.169,52.214.14.220)
PAYSTACK_WEBHOOK_ALLOWED_IPS=""
# Optional: where Paystack redirects after payment (web fallback; inline popup doesn't need it)
PAYSTACK_CALLBACK_URL="http://localhost:5173/payment-complete"
