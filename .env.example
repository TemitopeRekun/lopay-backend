NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Authentication (Backend JWT)
JWT_SECRET="replace-with-strong-secret"

# Firebase Admin SDK
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Supabase Storage (Private bucket + backend-signed URLs)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="your-private-bucket-name"
# Optional: default 600 seconds (10 minutes)
SUPABASE_SIGNED_URL_TTL_SECONDS=600

# Optional Admin Seed Config
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# Optional CORS allowlist (comma-separated)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=""
