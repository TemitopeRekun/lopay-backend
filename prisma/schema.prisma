// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
enum UserRole {
  SUPER_ADMIN
  SCHOOL_OWNER
  PARENT
}

enum PaymentStatus {
  PENDING
  ACTIVE
  COMPLETED
  DEFAULTED
  FAILED
}

enum PaymentTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum AuditAction {
  PAYMENT_CONFIRMED
  PAYMENT_REJECTED
  PAYMENT_REVERSED
  FIRST_PAYMENT_CONFIRMED
  FIRST_PAYMENT_SETTLED
  FIRST_PAYMENT_REJECTED
  FIRST_PAYMENT_PAID
  ENROLLMENT_DEFAULTED
}

enum PaymentType {
  FIRST_PAYMENT
  INSTALLMENT
}

enum PaymentReceiver {
  PLATFORM
  SCHOOL
}

enum InstallmentFrequency {
  WEEKLY
  MONTHLY
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  fullName  String?
  role      UserRole
  deletedAt DateTime?

  school    School?  @relation
  parent    Parent?
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

model School {
  id            String   @id @default(uuid())

  // Identity
  name          String
  email         String
  phone         String
  address       String

  // Ownership
  ownerId       String   @unique
  owner         User     @relation(fields: [ownerId], references: [id])

  // Bank / Settlement Info
  bankName      String
  bankCode      String?  // Paystack settlement bank code (e.g. "058"); required for subaccount
  accountName   String
  accountNumber String

  // Paystack split settlement
  paystackSubaccountCode    String?  @unique // e.g. "ACCT_xxxxxxxxxx"
  paystackSubaccountActive  Boolean  @default(false)

  deletedAt     DateTime?

  // Relations
  classes       ClassFee[]
  students      ChildEnrollment[]
  payments      Payment[]

  createdAt     DateTime @default(now())

  @@index([deletedAt])
}

model ClassFee {
  id         String  @id @default(uuid())
  schoolId   String
  className  String
  feeAmount  Int
  isActive   Boolean @default(true)

  school     School  @relation(fields: [schoolId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([schoolId, className])
}

model Parent {
  id          String   @id @default(uuid())
  userId      String   @unique
  phoneNumber String

  user        User     @relation(fields: [userId], references: [id])
  children    Child[]

  createdAt   DateTime @default(now())
}

model Child {
  id         String   @id @default(uuid())
  parentId   String
  fullName   String
  className  String

  parent     Parent   @relation(fields: [parentId], references: [id])
  enrollment ChildEnrollment?

  createdAt  DateTime @default(now())
}


model Payment {
  id              String           @id @default(uuid())
  enrollmentId    String
  schoolId        String

  idempotencyKey  String?          @unique // Client-generated key; prevents duplicate submissions on retry

  amountPaid      Int              // What parent paid
  platformAmount  Int              // Fixed 2.5% platform fee
  schoolAmount    Int              // Amount going to school (parent payment minus platform fee)

  receiver        PaymentReceiver  // School or platform

  paymentType     PaymentType
  status          PaymentTransactionStatus @default(PENDING)
  isConfirmed     Boolean          @default(false)
  paymentDate     DateTime         @default(now())
  receiptUrl      String?

  // Paystack (first-payment split). Null for manual installment payments.
  paystackReference  String?       @unique // Our generated transaction reference
  paystackAccessCode String?       // Returned by initialize; used by the inline popup
  amountCharged      Int?          // Gross amount parent paid (deposit + platform fee + paystack fee)
  paystackFee        Int?          // Actual Paystack fee (from charge.success webhook)
  transactionCharge  Int?          // Flat amount routed to platform main account (platformFee + paystackFee)

  enrollment      ChildEnrollment  @relation(fields: [enrollmentId], references: [id])
  school          School           @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([schoolId, isConfirmed, status])
  @@index([enrollmentId])
}

model ChildEnrollment {
  id                    String   @id @default(uuid())
  childId               String   @unique
  schoolId              String

  className             String

  totalSchoolFee        Int      // Snapshot of class fee at enrollment
  platformFee           Int      // 2.5% of totalSchoolFee, fixed
  schoolMinimumFee      Int      // 25% of totalSchoolFee

  firstPaymentPaid      Int      // Amount parent actually paid for first payment
  remainingBalance      Int      // Remaining balance after first payment & installments

  paymentStatus         PaymentStatus

  installmentFrequency  InstallmentFrequency
  termStartDate         DateTime
  termEndDate           DateTime

  child                 Child    @relation(fields: [childId], references: [id])
  school                School   @relation(fields: [schoolId], references: [id])
  payments              Payment[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([schoolId])
  @@index([schoolId, paymentStatus])
}

model PlatformSetting {
  id        String @id @default(uuid())
  key       String @unique
  value     String
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   // Who receives this notification (parent or school owner)
  title       String
  message     String
  isRead      Boolean  @default(false)
  link        String?  // Optional: frontend route to redirect
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
}

/// Append-only audit trail for money-state-changing actions. Rows are written
/// inside the same transaction as the change they describe and are never
/// updated or deleted.
model AuditLog {
  id          String      @id @default(uuid())
  action      AuditAction
  entityType  String // e.g. "Payment", "ChildEnrollment"
  entityId    String
  actorUserId String? // null for system/scheduler actions
  actorRole   String?
  schoolId    String?
  reason      String?
  before      Json?
  after       Json?
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([schoolId])
  @@index([createdAt])
}